{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    // ty is the project's type checker (just type-check). Turn Pylance's own
    // type checking off so diagnostics are not duplicated; Pylance still
    // provides completions, hover, and go-to-definition.
    "python.analysis.typeCheckingMode": "off",
    // Use the ty pinned in the project environment (.venv) so editor
    // diagnostics match `just type-check` rather than the extension's bundled
    // build.
    "ty.importStrategy": "fromEnvironment",
    "python.testing.pytestEnabled": true,
    "python.terminal.activateEnvironment": true,
    // Editor settings
    "editor.rulers": [
        88,
        119
    ],
    // Language-specific settings
    "[markdown]": {
        "editor.formatOnSave": false
    },
    "[python]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff"
    }
}